# Copy this file to .env for LOCAL use only. .env is gitignored.
# In cloud routines, set these as environment variables on the routine itself
# — do NOT create a .env file in the cloud (see CLAUDE.md).

# Alpaca — PAPER trading by default. Do not point this at the live endpoint
# without explicit sign-off; this whole system is designed/tested for paper.
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_paper_api_key_here
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key_here

# Financial Modeling Prep (per-symbol fundamentals: FCF, growth, analyst
# ratings). Free tier does NOT include sp500-constituent or the sector/
# market-cap screener — see TRADING-STRATEGY.md "Weekly Screen Refresh" for
# the free-tier workaround.
FMP_API_KEY=your_fmp_api_key_here
FMP_ENDPOINT=https://financialmodelingprep.com/stable

# Gemini Deep Research (catalyst/market research — background agent, 5-20 min/task)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_RESEARCH_POLL_SECONDS=20
GEMINI_RESEARCH_MAX_WAIT_SECONDS=1200

# Twilio SendGrid (notifications — email). SENDGRID_FROM_EMAIL must be a
# verified Sender Identity (Settings -> Sender Authentication in SendGrid) —
# unverified senders will get rejected, there's no test-sender shortcut.
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_verified_sender@yourdomain.com
SENDGRID_TO_EMAIL=seb@sebastianadamo.com
